default_platform(:android)

platform :android do
  desc "Upload signed AAB to Google Play"
  lane :deploy do |options|
    track = options[:track] || "internal"

    upload_to_play_store(
      track:                       track,
      aab:                         "../build/app/outputs/bundle/release/app-release.aab",
      json_key_data:               ENV.fetch("GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"),
      # Skip uploading assets that aren't changing
      skip_upload_apk:             true,
      skip_upload_metadata:        true,
      skip_upload_changelogs:      true,
      skip_upload_images:          true,
      skip_upload_screenshots:     true,
      # Use 'draft' so new apps don't need a completed prior release.
      # Change to 'completed' once the first release is live.
      release_status:              track == "production" ? "completed" : "draft",
      changes_not_sent_for_review: track != "production",
    )

    UI.success("✅ Uploaded to Play Store track: #{track}")
  end
end
