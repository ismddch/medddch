default_platform(:ios)

platform :ios do
  desc "Archive, sign and upload to TestFlight using manual codesigning"
  lane :beta do

    # ── App Store Connect API key ───────────────────────────────────────────
    api_key = app_store_connect_api_key(
      key_id:       ENV["APPSTORE_KEY_ID"],
      issuer_id:    ENV["APPSTORE_ISSUER_ID"],
      key_filepath: "/tmp/AuthKey.p8",
      duration:     1200,
      in_house:     false
    )

    # ── Switch project to manual signing ───────────────────────────────────
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "Runner.xcodeproj",
      team_id:               ENV["TEAM_ID"],
      code_sign_identity:    "iPhone Distribution",
      profile_name:          ENV["PROVISIONING_PROFILE_NAME"],
      bundle_identifier:     ENV["APP_IDENTIFIER"]
    )

    # ── Build and archive ───────────────────────────────────────────────────
    build_app(
      workspace:        "Runner.xcworkspace",
      scheme:           "Runner",
      configuration:    "Release",
      clean:            true,
      export_method:    "app-store",
      export_options: {
        method:       "app-store",
        teamID:       ENV["TEAM_ID"],
        signingStyle: "manual",
        provisioningProfiles: {
          ENV["APP_IDENTIFIER"] => ENV["PROVISIONING_PROFILE_NAME"]
        }
      },
      output_directory: "build",
      output_name:      "Hallaqak.ipa"
    )

    # ── Verify IPA exists before upload ────────────────────────────────────
    ipa_path = File.expand_path("build/Hallaqak.ipa")
    UI.important "IPA path: #{ipa_path}"
    UI.user_error! "IPA not found at #{ipa_path}" unless File.exist?(ipa_path)
    UI.success "IPA size: #{(File.size(ipa_path) / 1_048_576.0).round(1)} MB"

    # ── Upload to TestFlight ────────────────────────────────────────────────
    upload_to_testflight(
      api_key:                           api_key,
      app_identifier:                    ENV["APP_IDENTIFIER"],
      ipa:                               ipa_path,
      skip_waiting_for_build_processing: true,
      submit_beta_review:                false,
      notify_external_testers:           false
    )
  end
end
